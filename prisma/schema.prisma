generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model User {
  id              String    @id @db.Uuid
  email           String    @unique
  name            String
  phone           String?
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  role            String // 'client' | 'cleaner' | 'admin'
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaner                 Cleaner?
  client                  Client?
  sentMessages            Message[]                @relation("MessageSender")
  notifications           Notification[]
  googleCalendarToken     GoogleCalendarToken?
  cancelledBookings       Booking[]                @relation("BookingCancelledBy")
  raisedDisputes          Dispute[]                @relation("DisputeRaisedBy")
  resolvedDisputes        Dispute[]                @relation("DisputeResolvedBy")
  approvedCleaners        Cleaner[]                @relation("CleanerApprovedBy")
  issuedStrikes           CleanerStrike[]          @relation("StrikeIssuedBy")
  phoneVerificationEvents PhoneVerificationEvent[]

  @@map("users")
  @@schema("public")
}

model PhoneVerificationEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  phone     String
  eventType String   @map("event_type")
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, eventType, createdAt])
  @@index([userId, createdAt])
  @@map("phone_verification_events")
  @@schema("public")
}

model Cleaner {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    String    @unique @map("user_id") @db.Uuid
  bio                       String?
  profileImageUrl           String?   @map("profile_image_url")
  skills                    String[]  @default([])
  cleaningSupplies          String?   @map("cleaning_supplies") // own_supplies|client_supplies
  yearsExperience           Int       @default(0) @map("years_experience")
  hourlyRate                Decimal   @map("hourly_rate") @db.Decimal(10, 2)
  transportMode             String?   @map("transport_mode")
  transportPickupLocation   String?   @map("transport_pickup_location")
  idType                    String?   @map("id_type")
  idFileName                String?   @map("id_file_name")
  idFileUrl                 String?   @map("id_file_url")
  petAcceptance             Boolean   @default(false) @map("pet_acceptance")
  petComfortable            Boolean?  @map("pet_comfortable")
  workEligibilityAnswer     Boolean?  @map("work_eligibility_answer")
  workEligibilityConfirmed  Boolean   @default(false) @map("work_eligibility_confirmed")
  termsAccepted             Boolean   @default(false) @map("terms_accepted")
  cleaningStandardsAccepted Boolean   @default(false) @map("cleaning_standards_accepted")
  cleaningQuizScore         Int?      @map("cleaning_quiz_score")
  cleaningQuizPassedAt      DateTime? @map("cleaning_quiz_passed_at") @db.Timestamptz(6)
  standardsCompleted        Boolean   @default(false) @map("standards_completed")
  quizPassed                Boolean   @default(false) @map("quiz_passed")
  quizScore                 Int?      @map("quiz_score")
  onboardingStep            Int       @default(1) @map("onboarding_step")
  onboardingSkippedStep3    Boolean   @default(false) @map("onboarding_skipped_step3")
  onboardingSkippedStep4    Boolean   @default(false) @map("onboarding_skipped_step4")
  onboardingCompletedAt     DateTime? @map("onboarding_completed_at") @db.Timestamptz(6)
  status                    String    @default("pending") // pending|approved|rejected|suspended
  rejectionReason           String?   @map("rejection_reason")
  approvedAt                DateTime? @map("approved_at") @db.Timestamptz(6)
  approvedBy                String?   @map("approved_by") @db.Uuid
  profileComplete           Boolean   @default(false) @map("profile_complete")
  identityVerified          Boolean   @default(false) @map("identity_verified")
  stripeOnboardingComplete  Boolean   @default(false) @map("stripe_onboarding_complete")
  stripeAccountId           String?   @unique @map("stripe_account_id")
  totalJobs                 Int       @default(0) @map("total_jobs")
  averageRating             Decimal?  @map("average_rating") @db.Decimal(3, 2)
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedByUser        User?                        @relation("CleanerApprovedBy", fields: [approvedBy], references: [id])
  serviceAreas          ServiceArea[]
  availabilitySchedules AvailabilitySchedule[]
  blockedTimes          BlockedTime[]
  bookingsAsClean       Booking[]                    @relation("BookingCleaner")
  reviews               Review[]
  strikes               CleanerStrike[]
  reliabilitySnapshot   CleanerReliabilitySnapshot?
  reliabilityIncidents  CleanerReliabilityIncident[]
  cancellationEvents    CleanerCancellationEvent[]
  startVerifications    CleanerStartVerification[]
  favoritedByClients    ClientFavorite[]
  bookingFlowDrafts     BookingFlowDraft[]

  @@map("cleaners")
  @@schema("public")
}

model Client {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  defaultAddress   String?   @map("default_address")
  defaultCity      String?   @map("default_city")
  defaultPostcode  String?   @map("default_postcode")
  defaultCountry   String    @default("IE") @map("default_country")
  idFileName       String?   @map("id_file_name")
  idFileUrl        String?   @map("id_file_url")
  idSubmittedAt    DateTime? @map("id_submitted_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]          @relation("BookingClient")
  reviews           Review[]
  addresses         ClientAddress[]
  favorites         ClientFavorite[]
  bookingFlowDrafts BookingFlowDraft[]

  @@map("clients")
  @@schema("public")
}

model ClientAddress {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String   @map("client_id") @db.Uuid
  label            String?
  addressLine1     String   @map("address_line1")
  city             String
  postcode         String
  country          String   @default("IE")
  apartmentDetails String?  @map("apartment_details")
  accessNotes      String   @map("access_notes")
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  isDefault        Boolean  @default(false) @map("is_default")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_addresses")
  @@schema("public")
}

model ClientFavorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  cleanerId String   @map("cleaner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cleaner Cleaner @relation(fields: [cleanerId], references: [id], onDelete: Cascade)

  @@unique([clientId, cleanerId])
  @@index([clientId])
  @@index([cleanerId])
  @@map("client_favorites")
  @@schema("public")
}

model ServiceArea {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId      String   @map("cleaner_id") @db.Uuid
  city           String
  postcodePrefix String?  @map("postcode_prefix")
  radiusKm       Decimal? @map("radius_km") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  cleaner Cleaner @relation(fields: [cleanerId], references: [id], onDelete: Cascade)

  @@map("service_areas")
  @@schema("public")
}

model AvailabilitySchedule {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId     String   @map("cleaner_id") @db.Uuid
  dayOfWeek     Int      @map("day_of_week") // 1=Mon ... 7=Sun
  startTime     DateTime @map("start_time") @db.Time(6)
  endTime       DateTime @map("end_time") @db.Time(6)
  bufferMinutes Int      @default(30) @map("buffer_minutes")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaner Cleaner @relation(fields: [cleanerId], references: [id], onDelete: Cascade)

  @@unique([cleanerId, dayOfWeek, startTime, endTime])
  @@map("availability_schedules")
  @@schema("public")
}

model BlockedTime {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId     String   @map("cleaner_id") @db.Uuid
  startDatetime DateTime @map("start_datetime") @db.Timestamptz(6)
  endDatetime   DateTime @map("end_datetime") @db.Timestamptz(6)
  reason        String?
  bookingId     String?  @map("booking_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  cleaner Cleaner  @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("blocked_times")
  @@schema("public")
}

model Booking {
  id                            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId                      String    @map("client_id") @db.Uuid
  cleanerId                     String    @map("cleaner_id") @db.Uuid
  status                        String    @default("pending")
  serviceType                   String    @map("service_type")
  specialInstructions           String?   @map("special_instructions")
  address                       String
  city                          String
  postcode                      String
  country                       String    @default("IE")
  apartmentDetails              String?   @map("apartment_details")
  accessNotes                   String    @default("") @map("access_notes")
  scheduledStart                DateTime  @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd                  DateTime  @map("scheduled_end") @db.Timestamptz(6)
  durationHours                 Decimal   @map("duration_hours") @db.Decimal(4, 2)
  hourlyRate                    Decimal   @map("hourly_rate") @db.Decimal(10, 2)
  subtotal                      Decimal   @db.Decimal(10, 2)
  platformFeePct                Decimal   @default(10.00) @map("platform_fee_pct") @db.Decimal(5, 2)
  platformFee                   Decimal   @map("platform_fee") @db.Decimal(10, 2)
  cleanerPayout                 Decimal   @map("cleaner_payout") @db.Decimal(10, 2)
  totalAmount                   Decimal   @map("total_amount") @db.Decimal(10, 2)
  cancellationReason            String?   @map("cancellation_reason")
  cancelledBy                   String?   @map("cancelled_by") @db.Uuid
  cancelledAt                   DateTime? @map("cancelled_at") @db.Timestamptz(6)
  acceptedAt                    DateTime? @map("accepted_at") @db.Timestamptz(6)
  confirmedAt                   DateTime? @map("confirmed_at") @db.Timestamptz(6)
  startedAt                     DateTime? @map("started_at") @db.Timestamptz(6)
  startInitiatedBy              String?   @map("start_initiated_by")
  completedAt                   DateTime? @map("completed_at") @db.Timestamptz(6)
  acceptBy                      DateTime? @map("accept_by") @db.Timestamptz(6)
  payBy                         DateTime? @map("pay_by") @db.Timestamptz(6)
  proposedStart                 DateTime? @map("proposed_start") @db.Timestamptz(6)
  proposedEnd                   DateTime? @map("proposed_end") @db.Timestamptz(6)
  proposalBy                    String?   @map("proposal_by")
  proposalContext               String?   @map("proposal_context")
  proposalExpiresAt             DateTime? @map("proposal_expires_at") @db.Timestamptz(6)
  cleanerProposals              Int       @default(0) @map("cleaner_proposals")
  clientProposals               Int       @default(0) @map("client_proposals")
  postCleanerProposals          Int       @default(0) @map("post_cleaner_proposals")
  postClientProposals           Int       @default(0) @map("post_client_proposals")
  originalScheduledStart        DateTime? @map("original_scheduled_start") @db.Timestamptz(6)
  reauthorizationRequired       Boolean   @default(false) @map("reauthorization_required")
  reauthorizationGraceExpiresAt DateTime? @map("reauthorization_grace_expires_at") @db.Timestamptz(6)
  clientGcalEventId             String?   @map("client_gcal_event_id")
  cleanerGcalEventId            String?   @map("cleaner_gcal_event_id")
  serviceLatitude               Decimal?  @map("service_latitude") @db.Decimal(9, 6)
  serviceLongitude              Decimal?  @map("service_longitude") @db.Decimal(9, 6)
  geocodingProvider             String?   @map("geocoding_provider")
  geocodedAt                    DateTime? @map("geocoded_at") @db.Timestamptz(6)
  geocodingStatus               String?   @map("geocoding_status")
  createdAt                     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  client               Client                       @relation("BookingClient", fields: [clientId], references: [id])
  cleaner              Cleaner                      @relation("BookingCleaner", fields: [cleanerId], references: [id])
  cancelledByUser      User?                        @relation("BookingCancelledBy", fields: [cancelledBy], references: [id])
  payment              Payment?
  review               Review?
  dispute              Dispute?
  messages             Message[]
  blockedTimes         BlockedTime[]
  strikes              CleanerStrike[]
  actionEvents         BookingActionEvent[]
  reliabilityIncidents CleanerReliabilityIncident[]
  cancellationEvent    CleanerCancellationEvent?
  startVerification    CleanerStartVerification?
  bookingFlowDraft     BookingFlowDraft?

  @@index([clientId, createdAt(sort: Desc)], map: "bookings_client_created_desc_idx")
  @@index([cleanerId, createdAt(sort: Desc)], map: "bookings_cleaner_created_desc_idx")
  @@index([clientId, status, createdAt(sort: Desc)], map: "bookings_client_status_created_desc_idx")
  @@index([cleanerId, status, createdAt(sort: Desc)], map: "bookings_cleaner_status_created_desc_idx")
  @@index([status, createdAt(sort: Desc)], map: "bookings_status_created_desc_idx")
  @@index([status, acceptBy], map: "bookings_status_accept_by_idx")
  @@index([status, completedAt], map: "bookings_status_completed_at_idx")
  @@index([cleanerId, scheduledStart, scheduledEnd], map: "bookings_cleaner_schedule_idx")
  @@map("bookings")
  @@schema("public")
}

model BookingActionEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  type      String
  actorRole String?  @map("actor_role")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt], map: "booking_action_events_booking_created_idx")
  @@map("booking_action_events")
  @@schema("public")
}

model BookingFlowDraft {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  cleanerId     String    @map("cleaner_id") @db.Uuid
  bookingId     String?   @unique @map("booking_id") @db.Uuid
  lastStep      Int       @default(1) @map("last_step")
  durationHours Decimal?  @map("duration_hours") @db.Decimal(4, 2)
  selectedDate  String?   @map("selected_date")
  selectedSlot  DateTime? @map("selected_slot") @db.Timestamptz(6)
  payload       Json?     @map("payload")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cleaner Cleaner  @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([clientId, cleanerId])
  @@index([clientId, updatedAt])
  @@index([cleanerId, updatedAt])
  @@map("booking_flow_drafts")
  @@schema("public")
}

model Payment {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId             String    @unique @map("booking_id") @db.Uuid
  stripePaymentIntentId String    @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?   @unique @map("stripe_charge_id")
  stripeTransferId      String?   @unique @map("stripe_transfer_id")
  stripeRefundId        String?   @map("stripe_refund_id")
  amount                Decimal   @db.Decimal(10, 2)
  platformFee           Decimal   @map("platform_fee") @db.Decimal(10, 2)
  cleanerPayout         Decimal   @map("cleaner_payout") @db.Decimal(10, 2)
  currency              String    @default("eur")
  status                String    @default("pending")
  refundAmount          Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundReason          String?   @map("refund_reason")
  authorizedAt          DateTime? @map("authorized_at") @db.Timestamptz(6)
  capturedAt            DateTime? @map("captured_at") @db.Timestamptz(6)
  transferredAt         DateTime? @map("transferred_at") @db.Timestamptz(6)
  payoutScheduledAt     DateTime? @map("payout_scheduled_at") @db.Timestamptz(6)
  refundedAt            DateTime? @map("refunded_at") @db.Timestamptz(6)
  failedAt              DateTime? @map("failed_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status, bookingId], map: "payments_status_booking_idx")
  @@index([authorizedAt], map: "payments_authorized_at_idx")
  @@index([capturedAt], map: "payments_captured_at_idx")
  @@index([transferredAt], map: "payments_transferred_at_idx")
  @@map("payments")
  @@schema("public")
}

model Review {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String    @unique @map("booking_id") @db.Uuid
  cleanerId      String    @map("cleaner_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  rating         Int
  comment        String?
  cleanerReply   String?   @map("cleaner_reply")
  cleanerReplyAt DateTime? @map("cleaner_reply_at") @db.Timestamptz(6)
  isPublic       Boolean   @default(true) @map("is_public")
  hiddenByDispute Boolean  @default(false) @map("hidden_by_dispute")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id])
  cleaner Cleaner @relation(fields: [cleanerId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])

  @@map("reviews")
  @@schema("public")
}

model Dispute {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId             String    @unique @map("booking_id") @db.Uuid
  raisedBy              String    @map("raised_by") @db.Uuid
  reason                String
  issueType             String?   @map("issue_type")
  explanation           String?
  evidence              Json?
  status                String    @default("open")
  reporterRole          String?   @map("reporter_role")
  bookingStatusAtReport String?   @map("booking_status_at_report")
  responseExplanation   String?   @map("response_explanation")
  responseEvidence      Json?     @map("response_evidence")
  respondedBy           String?   @map("responded_by") @db.Uuid
  responderRole         String?   @map("responder_role")
  respondedAt           DateTime? @map("responded_at") @db.Timestamptz(6)
  resolutionType        String?   @map("resolution_type")
  noShowFinding         String?   @map("no_show_finding")
  resolutionNote        String?   @map("resolution_note")
  refundAmount          Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  resolvedBy            String?   @map("resolved_by") @db.Uuid
  resolvedAt            DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking        Booking @relation(fields: [bookingId], references: [id])
  raisedByUser   User    @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolvedByUser User?   @relation("DisputeResolvedBy", fields: [resolvedBy], references: [id])

  @@map("disputes")
  @@schema("public")
}

model CleanerStrike {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId  String    @map("cleaner_id") @db.Uuid
  bookingId  String?   @map("booking_id") @db.Uuid
  strikeType String    @map("strike_type")
  reason     String
  issuedBy   String?   @map("issued_by") @db.Uuid
  incidentId String?   @unique @map("incident_id") @db.Uuid
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  cleaner      Cleaner                     @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  booking      Booking?                    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  issuedByUser User?                       @relation("StrikeIssuedBy", fields: [issuedBy], references: [id])
  incident     CleanerReliabilityIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([cleanerId, expiresAt])
  @@map("cleaner_strikes")
  @@schema("public")
}

model CleanerReliabilitySnapshot {
  cleanerId                     String    @id @map("cleaner_id") @db.Uuid
  isSuperCleaner                Boolean   @default(false) @map("is_super_cleaner")
  completedReleasedCount        Int       @default(0) @map("completed_released_count")
  averageRating                 Decimal?  @map("average_rating") @db.Decimal(4, 2)
  cancellationNumerator         Int       @default(0) @map("cancellation_numerator")
  cancellationDenominator       Int       @default(0) @map("cancellation_denominator")
  cancellationRate              Decimal?  @map("cancellation_rate") @db.Decimal(6, 5)
  lastMinuteIncidentCount30d    Int       @default(0) @map("last_minute_incident_count_30d")
  noShowCount60d                Int       @default(0) @map("no_show_count_60d")
  verifiedJobCount              Int       @default(0) @map("verified_job_count")
  onTimeVerifiedCount           Int       @default(0) @map("on_time_verified_count")
  onTimeRate                    Decimal?  @map("on_time_rate") @db.Decimal(6, 5)
  activeStrikeCount             Int       @default(0) @map("active_strike_count")
  criteria                      Json
  recoveryCancellationStartedAt DateTime? @map("recovery_cancellation_started_at") @db.Timestamptz(6)
  recoveryNoShowStartedAt       DateTime? @map("recovery_no_show_started_at") @db.Timestamptz(6)
  lostAt                        DateTime? @map("lost_at") @db.Timestamptz(6)
  lossReason                    String?   @map("loss_reason")
  awardedAt                     DateTime? @map("awarded_at") @db.Timestamptz(6)
  nextEvaluationAt              DateTime? @map("next_evaluation_at") @db.Timestamptz(6)
  lastCalculatedAt              DateTime  @default(now()) @map("last_calculated_at") @db.Timestamptz(6)
  dirtyAt                       DateTime? @map("dirty_at") @db.Timestamptz(6)
  createdAt                     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaner Cleaner @relation(fields: [cleanerId], references: [id], onDelete: Cascade)

  @@index([isSuperCleaner])
  @@index([nextEvaluationAt])
  @@index([dirtyAt])
  @@map("cleaner_reliability_snapshots")
  @@schema("public")
}

model CleanerReliabilityIncident {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId    String   @map("cleaner_id") @db.Uuid
  bookingId    String?  @map("booking_id") @db.Uuid
  incidentType String   @map("incident_type")
  incidentDate String   @map("incident_date")
  sourceKey    String   @map("source_key")
  bookingIds   String[] @default([]) @map("booking_ids") @db.Uuid
  occurredAt   DateTime @map("occurred_at") @db.Timestamptz(6)
  latestAt     DateTime @map("latest_at") @db.Timestamptz(6)
  confirmedBy  String?  @map("confirmed_by") @db.Uuid
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaner Cleaner        @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  booking Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  strike  CleanerStrike?
  cancellationEvents CleanerCancellationEvent[]

  @@unique([cleanerId, incidentType, sourceKey])
  @@index([cleanerId, incidentType, occurredAt])
  @@map("cleaner_reliability_incidents")
  @@schema("public")
}

model CleanerCancellationEvent {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cleanerId          String   @map("cleaner_id") @db.Uuid
  bookingId          String   @unique @map("booking_id") @db.Uuid
  incidentId         String?  @map("incident_id") @db.Uuid
  cancelledByUserId  String   @map("cancelled_by_user_id") @db.Uuid
  cancellationWindow String   @map("cancellation_window")
  acceptedBooking    Boolean  @default(false) @map("accepted_booking")
  isLastMinute       Boolean  @default(false) @map("is_last_minute")
  scheduledStart     DateTime @map("scheduled_start") @db.Timestamptz(6)
  cancelledAt        DateTime @map("cancelled_at") @db.Timestamptz(6)
  hoursBeforeStart   Decimal  @map("hours_before_start") @db.Decimal(9, 3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  cleaner  Cleaner                     @relation(fields: [cleanerId], references: [id], onDelete: Cascade)
  booking  Booking                     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  incident CleanerReliabilityIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([cleanerId, cancellationWindow, cancelledAt])
  @@index([cleanerId, isLastMinute, cancelledAt])
  @@index([incidentId])
  @@map("cleaner_cancellation_events")
  @@schema("public")
}

model CleanerStartVerification {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId     String   @unique @map("booking_id") @db.Uuid
  cleanerId     String   @map("cleaner_id") @db.Uuid
