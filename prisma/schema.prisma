  longitude     Decimal? @db.Decimal(9, 6)
  accuracyM     Decimal? @map("accuracy_m") @db.Decimal(8, 2)
  distanceM     Decimal? @map("distance_m") @db.Decimal(10, 2)
  verified      Boolean  @default(false)
  onTime        Boolean  @default(false) @map("on_time")
  failureReason String?  @map("failure_reason")
  startedAt     DateTime @map("started_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cleaner Cleaner @relation(fields: [cleanerId], references: [id], onDelete: Cascade)

  @@index([cleanerId, verified, startedAt])
  @@map("cleaner_start_verifications")
